# Spotify - Get credentials from https://developer.spotify.com/dashboard
# For iOS app use: vibeplaylist://callback
# For local web testing: http://localhost:3000/callback
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=vibeplaylist://callback

# LiteLLM Proxy (optional - uses gemini-2.5-pro)
LITELLM_PROXY_URL=https://your-proxy-url
LITELLM_PROXY_API_KEY=your_proxy_api_key

# Gemini direct (fallback when proxy not configured)
# Get key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Optional: OpenAI for video audio transcription (Whisper)
OPENAI_API_KEY=

# Server
PORT=3000

# Optional: Reverse geocoding
MAPBOX_ACCESS_TOKEN=
# Or: GOOGLE_MAPS_API_KEY=
